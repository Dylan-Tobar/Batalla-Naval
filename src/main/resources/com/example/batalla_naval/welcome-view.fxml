<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane styleClass="app-background" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.batalla_naval.Controllers.WelcomeController">
   <children>
      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="440.0" spacing="14.0" style="-fx-background-color: rgba(15, 23, 42, 0.78); -fx-padding: 30px; -fx-border-color: #334155; -fx-border-radius: 12px; -fx-background-radius: 12px;">
         <children>
            <Label styleClass="hero-title" text=" BATALLA NAVAL " textAlignment="CENTER" wrapText="true" />
            <Label styleClass="hero-tagline" text="LA LUCHA CONTRA EL NARCOTRÁFICO" textAlignment="CENTER" wrapText="true" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #cbd5e1;" styleClass="army-text" text="Ingresa tu nombre de comandante para empezar" textAlignment="CENTER" wrapText="true" />
            <TextField fx:id="nicknameField" promptText="Tu nickname" />
            <Label fx:id="savedInfoLabel" managed="false" style="-fx-font-size: 12px; -fx-text-fill: #38bdf8;" styleClass="army-text" textAlignment="CENTER" visible="false" wrapText="true" />
            <Button fx:id="btnNewGame" maxWidth="1.7976931348623157E308" styleClass="action-button" text="🚀 Nueva Partida" />
            <Button fx:id="btnContinueGame" managed="false" maxWidth="1.7976931348623157E308" styleClass="secondary-button" text="🔄 Continuar Partida Guardada" visible="false" />
            <Label fx:id="errorLabel" style="-fx-font-size: 11px; -fx-text-fill: #f87171;" styleClass="army-text" textAlignment="CENTER" wrapText="true" />
         </children>
      </VBox>
   </children>
</StackPane>
